{
  "name": "oneroof",
  "private": true,
  "packageManager": "pnpm@10.8.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm -C apps/web dev",
    "build": "pnpm -r --filter=./apps/** --filter=./packages/** build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:up": "docker compose up -d --wait postgres",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && pnpm db:setup",
    "db:setup": "pnpm db:up && pnpm db:migrate",
    "db:generate": "pnpm -C packages/db generate",
    "db:migrate": "pnpm -C packages/db migrate",
    "db:push": "pnpm -C packages/db push",
    "db:studio": "pnpm -C packages/db studio",
    "db:seed": "pnpm -C packages/db seed"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "overrides": {
      "drizzle-orm": "^0.36.4"
    }
  }
}

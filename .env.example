# ─── Database ──────────────────────────────────────────────────────────────
# Local dev: `pnpm db:setup` boots the docker-compose Postgres on port 5433
# (5432 is reserved for the Home Doctor dev DB if both run concurrently).
# Swap for a Neon branch URL when deploying or if you prefer Neon locally.
DATABASE_URL="postgres://oneroof:oneroof@localhost:5433/oneroof"

# ─── Auth.js v5 ────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_TRUST_HOST="true"

# OAuth providers (optional for local dev — magic link works without them)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_APPLE_ID=""
AUTH_APPLE_SECRET=""

# ─── Envelope crypto (restricted fields) ───────────────────────────────────
# Base64-encoded 32-byte root key. Dev only — production swaps to KMS.
# Generate with: openssl rand -base64 32
ENVELOPE_ROOT_KEY=""

# ─── Cron auth ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
CRON_SECRET=""

# ─── Email delivery (Resend) ───────────────────────────────────────────────
# Magic-link sign-in requires this in production. Dev can use the no-op
# logger provider (see apps/web/src/lib/auth/providers.ts).
RESEND_API_KEY=""
RESEND_FROM="One Roof Homes <notifications@oneroofhomes.com>"

# ─── Stripe Connect (Phase 0 stub; live in Phase 1) ───────────────────────
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# STRIPE_PUBLISHABLE_KEY=""
# Connect platform account ID (acct_…). Required for Express onboarding.
# STRIPE_CONNECT_PLATFORM_ACCOUNT=""

# ─── Vercel Blob (job photos, COIs, license docs) ─────────────────────────
# BLOB_READ_WRITE_TOKEN=""

# ─── Inngest (background jobs) ─────────────────────────────────────────────
# In dev, the Inngest Dev Server auto-discovers functions without a key.
# INNGEST_EVENT_KEY=""
# INNGEST_SIGNING_KEY=""

# ─── Pusher (real-time messaging, lead arrival) ───────────────────────────
# PUSHER_APP_ID=""
# PUSHER_KEY=""
# PUSHER_SECRET=""
# PUSHER_CLUSTER=""
# NEXT_PUBLIC_PUSHER_KEY=""
# NEXT_PUBLIC_PUSHER_CLUSTER=""

# ─── Background checks (Checkr) ───────────────────────────────────────────
# CHECKR_API_KEY=""
# CHECKR_WEBHOOK_SECRET=""

# ─── Sentry ────────────────────────────────────────────────────────────────
# SENTRY_DSN=""
# SENTRY_ORG=""
# SENTRY_PROJECT=""
# SENTRY_AUTH_TOKEN=""
# NEXT_PUBLIC_SENTRY_DSN=""
# NEXT_PUBLIC_APP_ENV="production"

# ─── PostHog ────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_POSTHOG_KEY=""
# NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# ─── Home Doctor cross-product bridge ─────────────────────────────────────
# Inbound webhook signing for Home Doctor → One Roof events.
# HOMEDOCTOR_WEBHOOK_SECRET=""
# HOMEDOCTOR_BASE_URL="https://homedoctor.example.com"

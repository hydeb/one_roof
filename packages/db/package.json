{
  "name": "@oneroof/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate": "dotenv -e ../../.env.local -- drizzle-kit generate",
    "migrate": "dotenv -e ../../.env.local -- tsx src/migrate.ts",
    "push": "dotenv -e ../../.env.local -- drizzle-kit push",
    "studio": "dotenv -e ../../.env.local -- drizzle-kit studio",
    "seed": "dotenv -e ../../.env.local -- tsx src/seed.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@oneroof/shared": "workspace:*",
    "drizzle-orm": "^0.36.4",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "dotenv-cli": "^8.0.0",
    "drizzle-kit": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
